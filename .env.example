APP_ENV=production

; BASE_PATH — leave empty when public/ is the document root
; Set to /subfolder/path if public/ is in a subdirectory
BASE_PATH=

DB_HOST=localhost
DB_NAME=smartmall_db
DB_USER=root
DB_PASS=

CHAPA_SECRET_KEY=your_chapa_secret_key_here

BREVO_API_KEY=your_brevo_api_key_here
SMTP_FROM=noreply@smartmall.com

RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
